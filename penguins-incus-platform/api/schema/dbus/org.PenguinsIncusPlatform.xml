<!DOCTYPE node PUBLIC
  "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
  "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">

<!--
  D-Bus interface for the KIM daemon.

  Service:   org.PenguinsIncusPlatform
  Path:      /org/PenguinsIncusPlatform

  Every method here mirrors an operation in api/schema/openapi.yaml.
  All methods are asynchronous — they return an operation_id string.
  Results and state changes are delivered via signals.

  Type signatures follow D-Bus type notation:
    s  = string
    b  = boolean
    i  = int32
    u  = uint32
    a  = array
    v  = variant
    {} = dict entry
    a{sv} = array of string→variant dicts (used for structured objects)
-->

<node name="/org/PenguinsIncusPlatform">
  <interface name="org.PenguinsIncusPlatform">

    <!-- ── Instances ──────────────────────────────────────────────────────── -->

    <!--
      ListInstances: returns JSON array of InstanceSummary objects.
      project: project name filter ("" = default project)
      remote:  remote server name  ("" = local)
      type:    "container" | "virtual-machine" | "" (all)
    -->
    <method name="ListInstances">
      <arg name="project"   type="s" direction="in"/>
      <arg name="remote"    type="s" direction="in"/>
      <arg name="type"      type="s" direction="in"/>
      <arg name="instances" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <!--
      CreateInstance: config is a JSON-encoded InstanceConfig object.
      Returns operation_id; completion delivered via OperationCompleted signal.
    -->
    <method name="CreateInstance">
      <arg name="config"       type="s" direction="in"/>  <!-- JSON -->
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="GetInstance">
      <arg name="name"     type="s" direction="in"/>
      <arg name="project"  type="s" direction="in"/>
      <arg name="remote"   type="s" direction="in"/>
      <arg name="instance" type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="DeleteInstance">
      <arg name="name"         type="s" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="force"        type="b" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <!--
      ChangeInstanceState: action = start|stop|restart|freeze|unfreeze
    -->
    <method name="ChangeInstanceState">
      <arg name="name"         type="s" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="action"       type="s" direction="in"/>
      <arg name="force"        type="b" direction="in"/>
      <arg name="timeout"      type="i" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="RenameInstance">
      <arg name="name"         type="s" direction="in"/>
      <arg name="new_name"     type="s" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="ListSnapshots">
      <arg name="name"      type="s" direction="in"/>
      <arg name="project"   type="s" direction="in"/>
      <arg name="snapshots" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="CreateSnapshot">
      <arg name="name"         type="s" direction="in"/>
      <arg name="snapshot"     type="s" direction="in"/>
      <arg name="stateful"     type="b" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="RestoreSnapshot">
      <arg name="name"         type="s" direction="in"/>
      <arg name="snapshot"     type="s" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="DeleteSnapshot">
      <arg name="name"         type="s" direction="in"/>
      <arg name="snapshot"     type="s" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="GetInstanceLogs">
      <arg name="name"    type="s" direction="in"/>
      <arg name="project" type="s" direction="in"/>
      <arg name="logs"    type="s" direction="out"/>
    </method>

    <!--
      ConsoleInstance: attach to the serial or VGA console of an instance.
      type: "console" (serial, containers + VMs) | "vga" (VMs only)
      Returns a WebSocket URL on the daemon's HTTP server.
    -->
    <method name="ConsoleInstance">
      <arg name="name"    type="s" direction="in"/>
      <arg name="project" type="s" direction="in"/>
      <arg name="type"    type="s" direction="in"/>  <!-- console | vga -->
      <arg name="width"   type="i" direction="in"/>
      <arg name="height"  type="i" direction="in"/>
      <arg name="ws_url"  type="s" direction="out"/>
    </method>

    <!--
      ExecInstance: spawns a process in the container.
      Returns a WebSocket URL on the daemon's HTTP server for PTY I/O.
      Both the QML terminal widget and web UI xterm.js connect to this URL.
    -->
    <method name="ExecInstance">
      <arg name="name"        type="s" direction="in"/>
      <arg name="project"     type="s" direction="in"/>
      <arg name="command"     type="s" direction="in"/>
      <arg name="width"       type="i" direction="in"/>
      <arg name="height"      type="i" direction="in"/>
      <arg name="ws_url"      type="s" direction="out"/> <!-- ws://127.0.0.1:8765/... -->
    </method>

    <!--
      PullFile / PushFile: file content transferred as base64-encoded string
      to stay within D-Bus message size limits for small files.
      For large files, use the HTTP REST endpoint directly.
    -->
    <method name="PullFile">
      <arg name="name"           type="s" direction="in"/>
      <arg name="project"        type="s" direction="in"/>
      <arg name="path"           type="s" direction="in"/>
      <arg name="content_base64" type="s" direction="out"/>
    </method>

    <method name="PushFile">
      <arg name="name"           type="s" direction="in"/>
      <arg name="project"        type="s" direction="in"/>
      <arg name="path"           type="s" direction="in"/>
      <arg name="content_base64" type="s" direction="in"/>
      <arg name="mode"           type="s" direction="in"/> <!-- octal string e.g. "0644" -->
    </method>

    <!-- ── Networks ───────────────────────────────────────────────────────── -->

    <method name="ListNetworks">
      <arg name="project"  type="s" direction="in"/>
      <arg name="remote"   type="s" direction="in"/>
      <arg name="networks" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="CreateNetwork">
      <arg name="config"       type="s" direction="in"/>  <!-- JSON Network -->
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="GetNetwork">
      <arg name="name"    type="s" direction="in"/>
      <arg name="project" type="s" direction="in"/>
      <arg name="network" type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="UpdateNetwork">
      <arg name="name"    type="s" direction="in"/>
      <arg name="project" type="s" direction="in"/>
      <arg name="config"  type="s" direction="in"/>  <!-- JSON Network -->
    </method>

    <method name="DeleteNetwork">
      <arg name="name"         type="s" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <!-- ── Storage ────────────────────────────────────────────────────────── -->

    <method name="ListStoragePools">
      <arg name="remote" type="s" direction="in"/>
      <arg name="pools"  type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="CreateStoragePool">
      <arg name="config"       type="s" direction="in"/>  <!-- JSON StoragePool -->
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="GetStoragePool">
      <arg name="name" type="s" direction="in"/>
      <arg name="pool" type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="UpdateStoragePool">
      <arg name="name"   type="s" direction="in"/>
      <arg name="config" type="s" direction="in"/>
    </method>

    <method name="DeleteStoragePool">
      <arg name="name"         type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="ListStorageVolumes">
      <arg name="pool"    type="s" direction="in"/>
      <arg name="project" type="s" direction="in"/>
      <arg name="volumes" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="CreateStorageVolume">
      <arg name="pool"         type="s" direction="in"/>
      <arg name="config"       type="s" direction="in"/>  <!-- JSON StorageVolume -->
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="DeleteStorageVolume">
      <arg name="pool"         type="s" direction="in"/>
      <arg name="name"         type="s" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <!-- ── Images ─────────────────────────────────────────────────────────── -->

    <method name="ListImages">
      <arg name="remote" type="s" direction="in"/>
      <arg name="images" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="PullImage">
      <arg name="remote"       type="s" direction="in"/>
      <arg name="image"        type="s" direction="in"/>
      <arg name="alias"        type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="GetImage">
      <arg name="fingerprint" type="s" direction="in"/>
      <arg name="image"       type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="DeleteImage">
      <arg name="fingerprint"  type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <!-- ── Profiles ───────────────────────────────────────────────────────── -->

    <method name="ListProfiles">
      <arg name="project"  type="s" direction="in"/>
      <arg name="remote"   type="s" direction="in"/>
      <arg name="profiles" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="CreateProfile">
      <arg name="config"       type="s" direction="in"/>  <!-- JSON Profile -->
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="GetProfile">
      <arg name="name"    type="s" direction="in"/>
      <arg name="project" type="s" direction="in"/>
      <arg name="profile" type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="UpdateProfile">
      <arg name="name"    type="s" direction="in"/>
      <arg name="project" type="s" direction="in"/>
      <arg name="config"  type="s" direction="in"/>
    </method>

    <method name="DeleteProfile">
      <arg name="name"         type="s" direction="in"/>
      <arg name="project"      type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="ListProfilePresets">
      <arg name="presets" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <!-- ── Projects ───────────────────────────────────────────────────────── -->

    <method name="ListProjects">
      <arg name="remote"   type="s" direction="in"/>
      <arg name="projects" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="CreateProject">
      <arg name="config"       type="s" direction="in"/>  <!-- JSON Project -->
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="GetProject">
      <arg name="name"    type="s" direction="in"/>
      <arg name="project" type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="UpdateProject">
      <arg name="name"   type="s" direction="in"/>
      <arg name="config" type="s" direction="in"/>
    </method>

    <method name="DeleteProject">
      <arg name="name"         type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <!-- ── Cluster ────────────────────────────────────────────────────────── -->

    <method name="ListClusterMembers">
      <arg name="remote"  type="s" direction="in"/>
      <arg name="members" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="GetClusterMember">
      <arg name="name"   type="s" direction="in"/>
      <arg name="member" type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="RemoveClusterMember">
      <arg name="name"         type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="EvacuateClusterMember">
      <arg name="name"         type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="RestoreClusterMember">
      <arg name="name"         type="s" direction="in"/>
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <!-- ── Remotes ────────────────────────────────────────────────────────── -->

    <method name="ListRemotes">
      <arg name="remotes" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="AddRemote">
      <arg name="config" type="s" direction="in"/>  <!-- JSON Remote -->
    </method>

    <method name="GetRemote">
      <arg name="name"   type="s" direction="in"/>
      <arg name="remote" type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="RemoveRemote">
      <arg name="name" type="s" direction="in"/>
    </method>

    <!--
      ActivateRemote: switch the active remote for all subsequent calls.
    -->
    <method name="ActivateRemote">
      <arg name="name" type="s" direction="in"/>
    </method>

    <!-- ── Operations ─────────────────────────────────────────────────────── -->

    <method name="ListOperations">
      <arg name="status"     type="s" direction="in"/> <!-- "" = all -->
      <arg name="operations" type="s" direction="out"/> <!-- JSON array -->
    </method>

    <method name="GetOperation">
      <arg name="id"        type="s" direction="in"/>
      <arg name="operation" type="s" direction="out"/> <!-- JSON -->
    </method>

    <method name="CancelOperation">
      <arg name="id" type="s" direction="in"/>
    </method>

    <!-- ── Provisioning ───────────────────────────────────────────────────── -->

    <method name="DeployCompose">
      <arg name="config"       type="s" direction="in"/>  <!-- JSON ComposeDeployment -->
      <arg name="operation_id" type="s" direction="out"/>
    </method>

    <method name="ConvertCompose">
      <arg name="compose_yaml"  type="s" direction="in"/>
      <arg name="incus_compose" type="s" direction="out"/> <!-- JSON -->
    </method>

    <!-- ── Signals ────────────────────────────────────────────────────────── -->

    <!--
      OperationCompleted: fired when any async operation finishes.
      operation is a JSON-encoded Operation object.
    -->
    <signal name="OperationCompleted">
      <arg name="operation_id" type="s"/>
      <arg name="status"       type="s"/> <!-- succeeded|failed|cancelled -->
      <arg name="operation"    type="s"/> <!-- JSON Operation -->
    </signal>

    <!--
      InstanceStateChanged: fired when an instance changes state.
      Derived from the Incus lifecycle event stream.
    -->
    <signal name="InstanceStateChanged">
      <arg name="name"    type="s"/>
      <arg name="project" type="s"/>
      <arg name="status"  type="s"/> <!-- Running|Stopped|Frozen|Error -->
    </signal>

    <!--
      EventReceived: raw KIM event, JSON-encoded.
      Mirrors the SSE/WebSocket event stream for D-Bus subscribers.
      type: lifecycle|logging|network|operation|ovn
    -->
    <signal name="EventReceived">
      <arg name="type"      type="s"/>
      <arg name="project"   type="s"/>
      <arg name="timestamp" type="s"/> <!-- ISO 8601 -->
      <arg name="payload"   type="s"/> <!-- JSON metadata -->
    </signal>

    <!--
      ResourceUsageUpdated: periodic resource stats for running instances.
      Emitted approximately every 5 seconds per running instance.
    -->
    <signal name="ResourceUsageUpdated">
      <arg name="name"               type="s"/>
      <arg name="project"            type="s"/>
      <arg name="cpu_usage"          type="d"/> <!-- 0.0–1.0 -->
      <arg name="memory_usage_bytes" type="t"/> <!-- uint64 -->
      <arg name="disk_usage_bytes"   type="t"/> <!-- uint64 -->
    </signal>

  </interface>
</node>
